  create  table "neondb"."analytics"."fact_race_results__dbt_tmp"
  
  
    as
  
  (
    select
    r.race_id,
    r.driver_id,
    r.constructor_id,
    r.status_id,
    dr.season_year,
    r.result_id,
    r.driver_number,
    r.grid,
    r.position,
    r.position_text,
    r.position_order,
    r.points,
    r.laps,
    r.result_time,
    r.milliseconds,
    r.fastest_lap,
    r.fastest_lap_rank,
    r.fastest_lap_time,
    r.fastest_lap_speed,
    r.grid - r.position_order as finish_position_delta
from "neondb"."analytics"."stg_results" as r
inner join "neondb"."analytics"."dim_race" as dr
    on r.race_id = dr.race_id
  );
  
